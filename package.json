{
	"name": "sveltekit-adapter-middy",
	"version": "0.0.0-alpha.13",
	"description": "SvelteKit adapter for AWS Lambda with Middy",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"engineStrict": true,
	"workspaces": [
		".github"
	],
	"publishConfig": {
		"access": "public"
	},
	"module": "./index.js",
	"exports": {
		".": {
			"import": {
				"default": "./index.js"
			}
		}
	},
	"files": [
		"index.js",
		"handler.js",
		"sveltekitMiddleware.js",
		"sveltekitHandler.js"
	],
	"scripts": {
		"prepare": "husky",
		"git:pre-commit": "npm run git:lint-staged && npm run git:test-staged",
		"git:commit-msg": "commitlint --config commitlint.config.cjs --edit",
		"git:lint-staged": "npm run test:lint",
		"git:unit-staged": "node --test",
		"git:test-staged": "npm run git:unit-staged",
		"lint": "biome check --write --no-errors-on-unmatched",
		"test": "npm run test:lint && npm run test:unit && npm run test:types && npm run test:sast && npm run test:perf && npm run test:dast",
		"test:sast": "npm run test:sast:license",
		"test:sast:license": "license-check-and-add check -f license.json",
		"test:lint": "biome check --staged --no-errors-on-unmatched",
		"test:unit": "node --test --test-force-exit --experimental-test-coverage --test-coverage-lines=80 --test-coverage-branches=70 --test-coverage-functions=80 --test-coverage-exclude=sveltekitMiddleware.js --test-coverage-exclude=handler.js --test-coverage-exclude=index.js ./*.test.js",
		"test:types": "which tstyche > /dev/null 2>&1 && tstyche || echo 'tstyche not found, skipping type tests'",
		"test:perf": "node --test --test-concurrency=1 ./*.perf.js",
		"test:dast": "npm run test:dast:fuzz",
		"test:dast:fuzz": "node --test ./*.fuzz.js"
	},
	"license": "MIT",
	"keywords": [
		"SvelteKit",
		"Middy",
		"Lambda",
		"Middleware",
		"Serverless",
		"AWS",
		"AWS Lambda",
		"Middy",
		"HTTP",
		"SSR"
	],
	"author": {
		"name": "contributors",
		"url": "https://github.com/willfarrell/sveltekit-adapter-middy/graphs/contributors"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/willfarrell/sveltekit-adapter-middy.git",
		"directory": ""
	},
	"bugs": {
		"url": "https://github.com/willfarrell/sveltekit-adapter-middy/issues"
	},
	"homepage": "https://middy.js.org",
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/willfarrell"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@commitlint/cli": "^20.0.0",
		"@commitlint/config-conventional": "^20.0.0",
		"fast-check": "^4.0.0",
		"husky": "^9.0.0",
		"license-check-and-add": "4.0.5",
		"tinybench": "^6.0.0"
	},
	"dependencies": {
		"@datastream/string": "0.0.42",
		"@middy/core": "^7.0.0",
		"esbuild": "^0.27.0"
	}
}
